# ── Environment ───────────────────────────────────────────────────────────────
# "local" → PythonOperator tasks + LocalStack S3
# "production" → EmrServerlessStartJobRunOperator + real AWS
ENVIRONMENT=local

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ── S3 (production) ───────────────────────────────────────────────────────────
# Populated automatically by Terraform outputs via MWAA environment variables
S3_BUCKET=env-monitor-data-lake-<account-id>
S3_PREFIX=sensor-data
MWAA_BUCKET=env-monitor-airflow-<account-id>

# ── EMR Serverless (production) ───────────────────────────────────────────────
EMR_APPLICATION_ID=
EMR_EXECUTION_ROLE_ARN=

# ── Pipeline tuning ───────────────────────────────────────────────────────────
FETCH_INTERVAL_SECONDS=300
EXPECTED_SENSOR_COUNT=12

# ── Local dev only (docker-compose sets these automatically) ──────────────────
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
